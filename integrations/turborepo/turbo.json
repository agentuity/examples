{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build:routes": {
			"outputs": ["src/generated/**"]
		},
		"dev": {
			"dependsOn": ["@tanstack-turborepo/agentuity#build:routes"],
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".agentuity/**"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck", "@tanstack-turborepo/agentuity#build:routes"]
		}
	}
}
