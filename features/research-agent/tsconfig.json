{
	"compilerOptions": {
		"esModuleInterop": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"module": "Preserve",
		"moduleDetection": "force",
		"noEmit": true,
		"paths": {
			"@agent/*": ["./src/agent/*"],
			"@api/*": ["./src/api/*"],
			"@lib/*": ["./src/lib/*"],
			"@web/*": ["./src/web/*"]
		},
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ESNext",
		"verbatimModuleSyntax": true
	},
	"include": ["**/*.ts", "**/*.tsx"],
	"exclude": ["node_modules", ".agentuity"]
}
